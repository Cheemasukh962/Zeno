# GMI Cloud (OpenAI-compatible). Confirm BASE_URL in the GMI Discord (#agentbox).
GMI_API_KEY=sk-your-gmi-key
GMI_BASE_URL=https://api.gmi-serving.com/v1
GMI_BRAIN_MODEL=gemini-3-flash
GMI_VISION_MODEL=Qwen/Qwen3-VL-235B-A22B-Instruct-FP8

# Deepgram (you have credits). If blank, app falls back to text-only.
DEEPGRAM_API_KEY=
DEEPGRAM_TTS_MODEL=aura-asteria-en
DEEPGRAM_STT_MODEL=nova-2

# Redis
REDIS_URL=redis://localhost:6379

# Where annotated images / walkthroughs are served from
PUBLIC_BASE_URL=http://localhost:8000
